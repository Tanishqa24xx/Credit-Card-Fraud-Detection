import random

def get_risk_tier(probability):
    """
    Categorise fraud probability score into risk tier.
    """
    if probability < 0.10:
        return "🟢 Low Risk"
    elif probability < 0.50:
        return "🟡 Moderate Risk"
    elif probability < 0.90:
        return "🟠 High Risk"
    else:
        return "🔴 CRITICAL RISK"

def demonstrate_fraud_prediction(model, features, true_label=None):
    """
    Takes a single transaction feature set, predicts probability, and prints a risk report.
    """
    # Reshape input to (1, -1) because the model expects a 2D array for a single sample
    features_reshaped = features.values.reshape(1, -1)

    # Get Binary Prediction (0 or 1)
    prediction = model.predict(features_reshaped)[0]

    fraud_probability = model.predict_proba(features_reshaped)[0, 1]

    # Determine Risk Tier
    risk_tier = get_risk_tier(fraud_probability)

    print("-" * 60)
    print(f"🛑 FRAUD DETECTION REPORT")
    print("-" * 60)

    if true_label is not None:
        status = "FRAUD" if true_label == 1 else "LEGITIMATE"
        print(f"ACTUAL STATUS:       {status} (True Label: {true_label})")

    print(f"MODEL PREDICTION:    {'FRAUD' if prediction == 1 else 'LEGITIMATE'}")
    print(f"FRAUD PROBABILITY:   {fraud_probability:.2%}")
    print(f"RISK TIER:           {risk_tier}")
    print("-" * 60)

    # Insight into why (using top features defined in previous analysis)
    # Since V-features are anonymized, we can only show their values
    print("transaction snapshot (Key Scaled Features):")
    print(f"V14: {features['V14']:.4f} | V4: {features['V4']:.4f} | V12: {features['V12']:.4f}")
    print("-" * 60)
    print("\n")

# Demonstration

num_samples = 3

print(f"Simulating {num_samples} random transactions from the Test Pipeline...\n")

for i in range(num_samples):
    # Picking a random index from the test set
    random_index = random.choice(X_test_scaled.index)

    # Extracting its features and the true label for that index
    sample_features = X_test_scaled.loc[random_index]
    sample_label = y_test.loc[random_index]

    # Running the risk assessment model
    print(f"--- Transaction Simulation #{i+1} ---")
    demonstrate_fraud_prediction(best_model, sample_features, sample_label)
